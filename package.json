{
  "name": "weekly-eats",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "node scripts/dev-server.js",
    "dev:fast": "node scripts/dev-server.js --skip-setup",
    "dev:clean": "npm run clean && npm run dev",
    "build": "npm run setup-db && next build",
    "start": "next start",
    "lint": "eslint .",
    "setup-db": "node scripts/setup-database.js",
    "postinstall": "node scripts/setup-worktree.js",
    "test": "vitest run --run --pool=forks --maxWorkers=1 --isolate",
    "test:watch": "vitest",
    "test:coverage": "vitest run --run --coverage --pool=forks --maxWorkers=1 --isolate",
    "test:manual": "tsx test/manual/cli.ts",
    "test:manual:apply": "tsx test/manual/cli.ts apply",
    "test:manual:clean": "tsx test/manual/cli.ts clean",
    "test:manual:status": "tsx test/manual/cli.ts status",
    "test:manual:gen-catalog": "tsx test/manual/cli.ts gen-catalog",
    "test:manual:unlock": "tsx test/manual/cli.ts unlock",
    "seed:demo": "tsx test/manual/cli.ts apply --manifest demo",
    "check": "npm run lint -- --max-warnings=0 && npm run test:manual:gen-catalog -- --check && cross-env MONGODB_URI=mongodb://localhost:27017/fake SKIP_DB_SETUP=true npm run test:coverage && cross-env MONGODB_URI=mongodb://localhost:27017/fake SKIP_DB_SETUP=true npm run build",
    "worktree:remove": "node scripts/worktree-remove.js"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.9.1",
    "@date-io/date-fns": "^3.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@modelcontextprotocol/sdk": "1.26.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/material-nextjs": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.0",
    "@wei/pluralize": "npm:@jsr/wei__pluralize@^8.0.2",
    "ably": "^2.0.0",
    "convert": "^7.0.0",
    "date-fns": "^4.1.0",
    "mcp-handler": "^1.1.0",
    "mongodb": "^6.17.0",
    "next": "^16.0.0",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^29.0.0",
    "msw": "^2.10.4",
    "prettier": "^3.8.1",
    "tsx": "4.22.4",
    "typescript": "^6",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "zod": "^4.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "picomatch": "^4.0.4"
  }
}
